<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Territory Runner - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.24/dist/full.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        #territory-map {
            height: 460px;
            width: 100%;
            border-radius: 0.5rem;
            overflow: hidden;
        }
        @media (max-width: 640px) { #territory-map { height: 320px; } }
        .territory-tooltip {
            background: rgba(15,15,15,0.82) !important;
            border: none !important;
            border-radius: 12px !important;
            color: #fff !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            padding: 3px 10px !important;
            box-shadow: 0 1px 6px rgba(0,0,0,0.5) !important;
            white-space: nowrap !important;
            pointer-events: none !important;
        }
        .territory-tooltip::before { display: none !important; }
    </style>
</head>
<body class="min-h-screen bg-base-200">

    <!-- Navbar -->
    <header class="border-b border-base-300 bg-base-100 sticky top-0 z-50">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
            <h1 class="text-lg font-bold">🏃 Territory Runner</h1>
            <nav class="flex gap-2">
                <a href="/" class="btn btn-sm btn-ghost">Home</a>
                <a href="/leaderboard" class="btn btn-sm btn-outline">Leaderboard</a>
                <button onclick="logout()" class="btn btn-sm btn-error text-white">Logout</button>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8 space-y-8">

        <!-- Hero -->
        <section class="hero rounded-box bg-base-100 shadow-sm">
            <div class="hero-content py-12 text-center">
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold md:text-5xl">Welcome to Territory Running!</h2>
                    <p class="mt-3 text-base-content/70">Capture territories by running loops. The more you run, the more you own!</p>
                    <div class="mt-6">
                        <button class="btn btn-primary btn-lg" onclick="startRunning()">🚀 Start Running</button>
                        <a href="/leaderboard" class="btn btn-outline btn-lg ml-2">🏆 Leaderboard</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats -->
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body items-center text-center py-5">
                    <p class="text-3xl">📏</p>
                    <p class="text-2xl font-bold text-primary mt-1"><span id="total-distance">0</span> km</p>
                    <p class="text-base-content/60 text-xs uppercase tracking-widest mt-1">Total Distance</p>
                </div>
            </div>
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body items-center text-center py-5">
                    <p class="text-3xl">🗺️</p>
                    <p class="text-2xl font-bold text-success mt-1"><span id="total-area">0</span> m²</p>
                    <p class="text-base-content/60 text-xs uppercase tracking-widest mt-1">Territory Captured</p>
                </div>
            </div>
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body items-center text-center py-5">
                    <p class="text-3xl">🔥</p>
                    <p class="text-2xl font-bold text-warning mt-1"><span id="total-calories">0</span> kcal</p>
                    <p class="text-base-content/60 text-xs uppercase tracking-widest mt-1">Calories Burned</p>
                </div>
            </div>
        </section>

        <!-- Run History -->
        <section>
            <h3 class="text-lg font-bold mb-3">📋 Recent Running Sessions</h3>
            <div id="history-list" class="space-y-3">
                <div class="text-center text-base-content/50 py-6">Loading sessions...</div>
            </div>
        </section>

        <!-- Territory Map -->
        <section>
            <h3 class="text-lg font-bold mb-3">🗺️ Captured Territories</h3>
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body p-3">
                    <div id="territory-map"></div>
                </div>
            </div>
        </section>

    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/home.js"></script>
</body>
</html>
