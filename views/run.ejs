<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Run | Territory Runner</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.24/dist/full.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            overflow: hidden;
        }

        #map {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        #control-panel {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 10;
        }

        @media (min-width: 768px) {
            #map {
                left: 0;
                width: calc(100% - 320px);
            }

            #control-panel {
                top: 0;
                left: auto;
                right: 0;
                bottom: 0;
                width: 320px;
                overflow-y: auto;
            }
        }

        .territory-tooltip {
            background: rgba(15, 15, 15, 0.82) !important;
            border: none !important;
            border-radius: 12px !important;
            color: #fff !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            padding: 3px 10px !important;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.5) !important;
            white-space: nowrap !important;
            pointer-events: none !important;
        }

        .territory-tooltip::before {
            display: none !important;
        }
    </style>
</head>

<body class="bg-base-200">

    <!-- Full-screen Map -->
    <div id="map"></div>

    <!-- Control Panel -->
    <div id="control-panel"
        class="bg-base-100 border-t md:border-t-0 md:border-l border-base-300 shadow-xl flex flex-col">

        <!-- Header -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-base-300">
            <h1 class="font-bold text-base">🏃 Territory Running</h1>
            <a href="/" class="btn btn-ghost btn-sm">← Back</a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 divide-x divide-base-300 border-b border-base-300">
            <div class="flex flex-col items-center py-3 px-2">
                <p class="text-xs text-base-content/50 uppercase tracking-wide">Distance</p>
                <p class="font-bold text-primary" id="distance">0.00 km</p>
            </div>
            <div class="flex flex-col items-center py-3 px-2">
                <p class="text-xs text-base-content/50 uppercase tracking-wide">Time</p>
                <p class="font-bold" id="time">00:00:00</p>
            </div>
            <div class="flex flex-col items-center py-3 px-2">
                <p class="text-xs text-base-content/50 uppercase tracking-wide">Calories</p>
                <p class="font-bold text-warning" id="calories">0</p>
            </div>
        </div>

        <!-- Feedback -->
        <div class="px-4 py-2" id="session-feedback"></div>

        <!-- Buttons -->
        <div class="flex gap-3 px-4 py-4 mt-auto">
            <button id="pause-btn" onclick="pauseRun()" class="btn btn-warning flex-1"> Pause</button>
            <button id="finish-btn" onclick="finishRun()" class="btn btn-error flex-1 text-white"> Finish</button>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/run.js"></script>
</body>

</html>